  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/matiasbargas/company-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/matiasbargas/company-sdk/issues"
  },
  "homepage": "https://github.com/matiasbargas/company-sdk#readme",
  "files": [
    ".claude/commands/",
    "team/",
    "project-template/",
    "scripts/",
    "packages/",
    "AGENTS.md",
    "CLAUDE.md",
    "DISCLAIMER.md",
    "README.md",
    "SDK.md",
    "STRATEGY.md",
    "protocol.md"
  ],
  "bin": {
    "sdk-bootstrap": "./scripts/bootstrap.js",
    "sdk-doc": "./scripts/doc.js",
    "sdk-gate-check": "./scripts/gate-check.js",
    "sdk-init": "./scripts/init.js",
    "sdk-kill": "./scripts/kill.js",
    "sdk-squad": "./scripts/squad.js",
    "sdk-next": "./scripts/next.js",
    "sdk-resume": "./scripts/resume.js",
    "sdk-github": "./scripts/github.js",
    "sdk-health": "./scripts/health.js",
    "sdk-retro": "./scripts/retro.js",
    "sdk-ship": "./scripts/ship.js",
    "sdk-status": "./scripts/status.js",
    "sdk-update": "./scripts/update.js",
    "sdk-validate": "./scripts/validate.js",
    "sdk-pre-tag": "./scripts/pre-tag.js",
    "sdk-version": "./scripts/version.js",
    "sdk-daemon": "./scripts/daemon.js",
    "sdk-ops": "./scripts/ops.js",
    "sdk-consult": "./scripts/consult.js",
    "sdk-memory": "./scripts/memory.js"
  },
  "scripts": {
    "bootstrap": "node scripts/bootstrap.js",
    "squad": "node scripts/squad.js",
