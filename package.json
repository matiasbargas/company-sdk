    "test": "node scripts/lib/test-ship.js && node scripts/lib/test-validate.js && node scripts/lib/test-v4.js && node packages/protocol/tests/run.js && node packages/context/tests/run.js && node packages/cli/tests/run.js && node packages/memory/tests/run.js && node packages/runtime/tests/run.js"
  },
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=18"
  }
